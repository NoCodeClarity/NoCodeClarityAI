# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
WALLET_MNEMONIC="your twelve word mnemonic phrase goes here"
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nocodeclarity

# ── Optional ──────────────────────────────────────────────────────────────────
HIRO_API_KEY=
STACKS_NETWORK=testnet
ORCHESTRATOR_PORT=3001
ORCHESTRATOR_SECRET=change-me-in-production

# Embeddings (true semantic search when set, falls back to hash vectors)
OPENAI_API_KEY=

# AIBTC Registration (optional)
AIBTC_REGISTER=false
AIBTC_OPERATOR_X_HANDLE=

# ── Frontend ──────────────────────────────────────────────────────────────────
# The React frontend runs separately via Netlify or `npm run dev` in packages/frontend.
# When self-hosting, the orchestrator serves the frontend from packages/frontend/dist.
# For Netlify, set the API proxy in packages/frontend/public/_redirects.
